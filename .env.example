# Database — Neon (ohne Docker) oder lokales PostgreSQL
# Neon: https://neon.tech → Projekt anlegen → Connection String kopieren
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Auth.js — Secret erzeugen: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="change-me-in-production"
AUTH_URL="http://localhost:3000"

# Storage
# Lokal: local (Dateien in public/uploads/)
# Production (Vercel): s3 + Cloudflare R2 — siehe .env.production.example
STORAGE_MODE="local"

# Cloudflare R2 / S3 — nur bei STORAGE_MODE=s3
# S3_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
# S3_REGION="auto"
# S3_BUCKET="chronikon-attachments"
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""
# S3_PUBLIC_URL=""   # optional — sonst /api/files/… mit Login

# KI — Mock ohne OpenAI-Key
OPENAI_API_KEY=""
AI_MOCK_MODE="true"

# Optional: Admin beim Seed (npm run db:seed)
# SEED_ADMIN_EMAIL="admin@chronikon.dev"
# SEED_ADMIN_PASSWORD="Chronikon-Admin-2026!"

# Einladungen: nur per Link (kein E-Mail-Versand). Admin erstellt Einladung unter /admin/users.
